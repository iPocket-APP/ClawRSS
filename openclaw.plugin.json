{
  "id": "openclaw-rss",
  "name": "OpenClaw RSS Sync",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dbPath": {
        "type": "string",
        "description": "SQLite file path for openclaw-rss data"
      },
      "defaultLimit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500,
        "description": "Default page size used by openclaw_rss_pull"
      },
      "maxPagesPerSync": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "description": "Recommended max pages to pull in a single sync cycle"
      },
      "pushTargetURL": {
        "type": "string",
        "description": "Full Bark-style push URL generated by the ClawRSS app"
      },
      "pushRelayBaseURL": {
        "type": "string",
        "description": "Base URL of the ClawRSS push relay for app-wide fanout delivery"
      },
      "pushAppID": {
        "type": "string",
        "description": "Logical appID registered with the ClawRSS push relay"
      },
      "pushTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 60000,
        "description": "Timeout for relay requests in milliseconds"
      }
    }
  },
  "uiHints": {
    "dbPath": {
      "label": "SQLite DB Path",
      "placeholder": "~/.openclaw/clawrss-sync.db"
    },
    "defaultLimit": {
      "label": "Default Pull Limit"
    },
    "maxPagesPerSync": {
      "label": "Max Pages Per Sync"
    },
    "pushTargetURL": {
      "label": "Apple Push URL",
      "placeholder": "https://clawrss-apns.example.com/p/abcdef123456"
    },
    "pushRelayBaseURL": {
      "label": "Push Relay Base URL",
      "placeholder": "https://push.example.com"
    },
    "pushAppID": {
      "label": "Push App ID",
      "placeholder": "claw-rss"
    },
    "pushTimeoutMs": {
      "label": "Push Timeout (ms)"
    }
  },
  "skills": [
    "skills"
  ]
}
